# Suppress code coverage and profiling instrumentation.
# Deletes the specific asm statement containing the matched symbol.

if:
  at beforeIrAnalyzation
  asm_contains __gcov
do:
  del start[0]

if:
  at beforeIrAnalyzation
  asm_contains __llvm_profile
do:
  del start[0]

if:
  at beforeIrAnalyzation
  asm_contains __llvm_gcov
do:
  del start[0]
