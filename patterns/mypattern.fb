# comments are ignored

if:
  asm mov rsp, 8
  asm push rbp

if: # multiple if blocks are OR
  asm `asm mov rsp, 8; asm push rbp`

do:
  asm mov esp, 8
  ir halt
  ast comment prologue rewritten by pattern
  info("prologue pattern matched")
  warn("check stack prologue rewrite")
  error("prologue rewrite emitted an error log")
  debug("prologue rewrite debug details")
  trace("prologue rewrite trace details")
