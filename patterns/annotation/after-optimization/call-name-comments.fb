if:
  at afterOptimization
  stmt Call($f)
  where call_name_matches($f, "emutls")
do:
  emit_comment "// thread-local storage access"

# Rust panic / unwind
if:
  at afterOptimization
  stmt Call($f)
  where call_name_matches($f, "rust_begin_unwind")
do:
  emit_comment "// Rust panic / unwind runtime"

if:
  at afterOptimization
  stmt Call($f)
  where call_name_matches($f, "rust_panic")
do:
  emit_comment "// Rust panic / unwind runtime"

# Non-local jumps
if:
  at afterOptimization
  stmt Call($f)
  where call_name_matches($f, "setjmp")
do:
  emit_comment "// non-local jump (setjmp/longjmp)"

if:
  at afterOptimization
  stmt Call($f)
  where call_name_matches($f, "longjmp")
do:
  emit_comment "// non-local jump (setjmp/longjmp)"

