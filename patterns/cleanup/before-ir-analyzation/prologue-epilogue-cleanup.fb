# Remove x86 function prologue/epilogue instruction sequences.
# push rbp; mov rbp,rsp  and  mov rsp,rbp; pop rbp  are replaced with comments.

if:
  at beforeIrAnalyzation
  asm `push rbp; mov rbp, rsp`
do:
  ast comment // function prologue
  del start[0..2]
if:
  at beforeIrAnalyzation
  asm `mov rsp, rbp; pop rbp`
do:
  ast comment // function epilogue
  del start[0..2]
if:
  at beforeIrAnalyzation
  asm pop rbp
do:
  ast comment // function epilogue
  del start[0]
